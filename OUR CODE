# ─────────────────────────────────────────────────────────
# STEP 2 — MOLECULAR FINGERPRINTING
# Converts SMILES string → numbers the ML model can read
# This is the core computational chemistry part!
# ─────────────────────────────────────────────────────────
 
FUNCTIONAL_GROUPS = {
    "carboxylic_acid":  r"C\(=O\)O(?!C)",
    "ester":            r"C\(=O\)OC",
    "amide":            r"C\(=O\)N",
    "hydroxyl":         r"(?<![=])O(?!C|=|\[)",
    "ether":            r"[CO]OC",
    "ketone":           r"CC\(=O\)C",
    "nitro_group":      r"\[N\+\]\(=O\)\[O-\]",
    "amine_primary":    r"(?<![CN])N(?![H]?\d)",
    "amine_secondary":  r"[CN]N[CN]",
    "amine_tertiary":   r"N\([^)]+\)[^)]+",
    "fluorine":         r"F",
    "chlorine":         r"Cl",
    "bromine":          r"Br",
    "thiol":            r"S(?!O|=|\()",
    "sulfoxide":        r"S\(=O\)",
    "sulfonamide":      r"S\(=O\)\(=O\)N",
    "benzene_ring":     r"c1ccccc1",
    "aromatic_hetero":  r"c1cc[nN]",
    "imidazole":        r"n1ccnc1",
    "pyridine":         r"c1ccncc1",
    "chiral_center":    r"\[C@@H\]|\[C@H\]",
    "peroxide":         r"OO",
    "imine":            r"C=N",
    "long_chain":       r"CCCCCC",
    "steroid_core":     r"C1CC2CCCC",
}
 
TOXICOPHORES = {
    "nsaid_scaffold":       r"CC.*c1ccc.*C\(=O\)O",
    "acetaminophen_like":   r"CC\(=O\)Nc1ccc\(O\)",
    "salicylate":           r"c1ccccc1C\(=O\)O",
    "cardiac_glycoside":    r"C\(=O\)OC.*OC",
    "warfarin_like":        r"c1ccccc1.*oc.*=O",
    "xylitol_like":         r"OCC\(O\)C\(O\)",
    "permethrin_like":      r"C1CC\(C1\).*OCc",
    "pyrethroid":           r"C\(=O\)OC.*C1CC",
    "alcohol_simple":       r"^CCO$",
    "propylene_glycol":     r"CC\(O\)CO",
    "metal_compound":       r"\[Zn\]|Zn|=\[Zn\]",
}
 
def smiles_to_features(smiles):
    """Turn a SMILES string into a list of numbers (the fingerprint)."""
    features = []
    for pattern in list(FUNCTIONAL_GROUPS.values()) + list(TOXICOPHORES.values()):
        features.append(1 if re.search(pattern, smiles) else 0)
    # Physicochemical descriptors
    features.append(len(re.findall(r"[A-Z][a-z]?", smiles)) / 50.0)
    features.append(smiles.count("1") / 5.0)
    features.append(len(re.findall(r"[a-z]", smiles)) / 20.0)
    features.append(len(re.findall(r"[NOSPF]", smiles)) / 10.0)
    return np.array(features, dtype=np.float32)
 
# ─────────────────────────────────────────────────────────
# STEP 3 — TRAIN THE MODEL
# ─────────────────────────────────────────────────────────
 
def train():
    """Train classifiers for dogs and cats. Returns model dict."""
    df = pd.DataFrame(DATASET, columns=["name","smiles","toxic_dogs","toxic_cats","organ","severity"])
    X  = np.array([smiles_to_features(s) for s in df["smiles"]])
    models = {}
 
    for animal in ["dogs", "cats"]:
        y = df[f"toxic_{animal}"].values
 
        clf = RandomForestClassifier(n_estimators=200, max_depth=6,
                                     random_state=42, class_weight="balanced")
        clf.fit(X, y)
 
        # Organ classifier (only on toxic rows)
        mask   = y == 1
        le     = LabelEncoder()
        y_org  = le.fit_transform(df.loc[mask, "organ"].values)
        clf_org = RandomForestClassifier(n_estimators=200, max_depth=6,
                                          random_state=42, class_weight="balanced")
        clf_org.fit(X[mask], y_org)
 
        models[animal] = {"tox": clf, "org": clf_org, "le": le}
 
    return models, df
 
# ─────────────────────────────────────────────────────────
# STEP 4 — PREDICT
# ─────────────────────────────────────────────────────────
 
def predict(smiles, models):
    feat = smiles_to_features(smiles).reshape(1, -1)
    result = {}
    for animal, m in models.items():
        is_toxic   = m["tox"].predict(feat)[0]
        confidence = m["tox"].predict_proba(feat)[0][is_toxic] * 100
        organ      = m["le"].inverse_transform(m["org"].predict(feat))[0] if is_toxic else "None"
        result[animal] = {"toxic": bool(is_toxic), "confidence": round(confidence, 1), "organ": organ}
    return result
 
