def show_result(name, smiles, result, ref=None):
    print("\n" + "═"*56)
    print("   🐾  PET DRUG SAFETY PREDICTOR")
    print("═"*56)
    print(f"   Drug   : {name}")
    print(f"   SMILES : {smiles[:48]}{'...' if len(smiles)>48 else ''}")
    print("─"*56)
    for animal, emoji in [("dogs","🐕"), ("cats","🐈")]:
        r = result[animal]
        status = "☠️  TOXIC" if r["toxic"] else "✅  SAFE "
        print(f"\n   {emoji} {animal.upper()}")
        print(f"      Status     : {status}")
        print(f"      Confidence : {r['confidence']}%")
        print(f"      Organ Risk : {r['organ']}")
    print("\n" + "─"*56)
    if ref is not None:
        sev = ref.get("severity","")
        icons = {"High":"🔴","Medium":"🟠","Low":"🟡","None":"🟢"}
        icon  = icons.get(str(sev), "⚪")
        print(f"   📋 Notes    : {ref.get('notes','N/A')}")
        print(f"   ⚠️  Severity  : {icon} {sev}")
    print("\n   ⚠️  DISCLAIMER: For education only. Always ask a vet.")
    print("═"*56 + "\n")
 
def show_list(df):
    print("\n" + "─"*65)
    print(f"  {'Name':<22} {'Dogs':^12} {'Cats':^12} {'Organ':<15}")
    print("─"*65)
    for _, row in df.iterrows():
        d = "☠ Toxic" if row["toxic_dogs"] else "✅ Safe"
        c = "☠ Toxic" if row["toxic_cats"] else "✅ Safe"
        print(f"  {row['name']:<22} {d:^12} {c:^12} {row['organ']:<15}")
    print("─"*65 + "\n")
 
