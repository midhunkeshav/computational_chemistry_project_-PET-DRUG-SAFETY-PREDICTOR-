# STEP 6 — INTERACTIVE MENU
# ─────────────────────────────────────────────────────────
 
def run():
    print("\n🔬 Training model on 40 pet drug records...", end=" ", flush=True)
    models, df = train()
    print("Done! ✅\n")
 
    while True:
        print("━"*40)
        print("  What do you want to do?")
        print("  1. Check a drug by NAME")
        print("  2. Check a drug by SMILES string")
        print("  3. See full list of all 40 drugs")
        print("  4. Exit")
        print("━"*40)
        choice = input("  Enter 1 / 2 / 3 / 4 : ").strip()
 
        if choice == "1":
            name = input("\n  Enter drug name (e.g. Ibuprofen): ").strip()
            match = df[df["name"].str.lower() == name.lower()]
            if match.empty:
                print(f"\n  ❌ '{name}' not found. Try option 3 to see the full list.\n")
                continue
            row    = match.iloc[0]
            result = predict(row["smiles"], models)
            ref    = {"notes": f"Known toxicity record from dataset", "severity": row["severity"]}
            show_result(row["name"], row["smiles"], result, ref)
 
        elif choice == "2":
            name   = input("\n  Enter a name/label for this molecule: ").strip()
            smiles = input("  Enter SMILES string: ").strip()
            if not smiles:
                print("  ❌ SMILES cannot be empty.\n")
                continue
            try:
                result = predict(smiles, models)
                show_result(name, smiles, result)
            except Exception as e:
                print(f"  ❌ Error processing SMILES: {e}\n")
 
        elif choice == "3":
            show_list(df)
 
        elif choice == "4":
            print("\n  👋 Goodbye! Remember — always consult a vet.\n")
            break
 
        else:
            print("  ❌ Invalid choice. Please enter 1, 2, 3 or 4.\n")
 
